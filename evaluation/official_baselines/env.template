# 官方 baseline API 配置模板
#
# 使用方式：
# 1. 不要把真实 key 写进 Git。
# 2. 在终端里 source 你自己的本地文件，例如：
#    source evaluation/official_baselines/.env.local
# 3. .env.local 已被 .gitignore 的 .env.* 规则忽略。

# RAPTOR 官方代码读取这个变量。
export OPENAI_API_KEY="sk-your-openai-api-key"

# Microsoft GraphRAG 默认配置读取这个变量。
# 如果你用 OpenAI 官方 API，通常可以和 OPENAI_API_KEY 相同。
export GRAPHRAG_API_KEY="$OPENAI_API_KEY"

# 如果后续要跑 HippoRAG 的 OpenAI 模式，也会读取 OPENAI_API_KEY。
# HippoRAG 在本机 macOS 上暂不安装，因为官方依赖 vllm 更适合 Linux/CUDA。

# 可选：OpenAI-compatible 服务地址。
# 注意：RAPTOR 官方代码当前直接调用 OpenAI(api_key=...)，不稳定支持 base_url。
# GraphRAG / HippoRAG 更容易配置 OpenAI-compatible base url。
# export OPENAI_BASE_URL="https://api.openai.com/v1"
