# 官方 baseline API 配置模板
#
# 使用方式：
# 1. 不要把真实 key 写进 Git。
# 2. 在终端里 source 你自己的本地文件，例如：
#    source evaluation/official_baselines/.env.local
# 3. .env.local 已被 .gitignore 的 .env.* 规则忽略。

# 情况 A：公司网关是普通 OpenAI-compatible /v1。
# 注意：base url 通常必须带 /v1，例如 https://your-company-gateway.example.com/v1
export OPENAI_API_KEY="your-company-api-key"
export OPENAI_BASE_URL="https://your-company-openai-compatible-base-url/v1"

# 情况 B：公司网关是 Azure-style deployment 路径。
# 例如实际请求形态为：
#   {GPT54_BASE_URL}/openai/deployments/{GPT54_MODEL}/chat/completions?api-version={GPT54_API_VERSION}
export GPT54_API_KEY="$OPENAI_API_KEY"
export GPT54_BASE_URL="https://your-company-gateway.example.com/path"
export GPT54_API_VERSION="2024-02-01"
export GPT54_MODEL="your-chat-deployment"

# RAPTOR 配置。
export RAPTOR_CLIENT_TYPE="openai" # 如果是 Azure-style deployment 路径，改成 azure
export RAPTOR_AZURE_ENDPOINT="$GPT54_BASE_URL"
export RAPTOR_API_VERSION="$GPT54_API_VERSION"
export RAPTOR_QA_MODEL="your-chat-model"
export RAPTOR_SUMMARY_MODEL="$RAPTOR_QA_MODEL"
export RAPTOR_EMBEDDING_MODEL="your-embedding-model"

# Microsoft GraphRAG 配置。
export GRAPHRAG_API_KEY="$OPENAI_API_KEY" # Azure-style 可改成 "$GPT54_API_KEY"
export GRAPHRAG_API_BASE="$OPENAI_BASE_URL" # Azure-style 可改成 "$GPT54_BASE_URL"
export GRAPHRAG_API_VERSION="$GPT54_API_VERSION"
export GRAPHRAG_MODEL_PROVIDER="openai" # Azure-style 改成 azure
export GRAPHRAG_CHAT_MODEL="$RAPTOR_QA_MODEL"
export GRAPHRAG_EMBEDDING_MODEL="$RAPTOR_EMBEDDING_MODEL"
export GRAPHRAG_CHAT_DEPLOYMENT="$GRAPHRAG_CHAT_MODEL"
export GRAPHRAG_EMBEDDING_DEPLOYMENT="$GRAPHRAG_EMBEDDING_MODEL"

# 如果后续要跑 HippoRAG 的 OpenAI 模式，也会读取 OPENAI_API_KEY。
# HippoRAG 在本机 macOS 上暂不安装，因为官方依赖 vllm 更适合 Linux/CUDA。

# 如果你们公司网关要求额外 HTTP header、AK/SK 签名或非 Azure/OpenAI-compatible
# 路径，需要再做一层客户端适配。
